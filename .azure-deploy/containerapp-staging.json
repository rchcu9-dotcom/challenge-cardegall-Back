{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": { "type": "string", "defaultValue": "westeurope" },
    "envName": { "type": "string", "defaultValue": "cae-cardegall-staging" },
    "appName": { "type": "string", "defaultValue": "challenge-cardegall-back" },
    "image": { "type": "string" },
    "acrLoginServer": { "type": "string" },
    "acrUsername": { "type": "string" },
    "acrPassword": { "type": "securestring" }
  },
  "resources": [
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2026-03-02-preview",
      "name": "[parameters('envName')]",
      "location": "[parameters('location')]",
      "properties": {}
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2026-03-02-preview",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', parameters('envName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', parameters('envName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 3010,
            "transport": "auto"
          },
          "registries": [
            {
              "server": "[parameters('acrLoginServer')]",
              "username": "[parameters('acrUsername')]",
              "passwordSecretRef": "acr-password"
            }
          ],
          "secrets": [
            {
              "name": "acr-password",
              "value": "[parameters('acrPassword')]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('appName')]",
              "image": "[parameters('image')]",
              "env": [
                { "name": "PORT", "value": "3010" }
              ],
              "resources": {
                "cpu": 0.5,
                "memory": "1Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 2
          }
        }
      }
    }
  ],
  "outputs": {
    "fqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('appName'))).configuration.ingress.fqdn]"
    }
  }
}
