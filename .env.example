PORT=3010
CORS_ORIGINS=http://localhost:5183

# ─── Base de données (Prisma / MySQL AlwaysData) ───────────────────
DATABASE_URL="mysql://<user>:<password>@<host>:3306/<database>?ssl=true"

# ─── Auth (Passport.js + JWT) ─────────────────────────────────────
JWT_SECRET=<chaine-aleatoire-longue>
JWT_EXPIRES_IN=7d
# Tant que ces deux valeurs sont absentes/placeholders, GET /auth/google répond 503
# et POST /auth/dev-login (dev uniquement) permet de tester l'app sans Google.
GOOGLE_CLIENT_ID=<depuis-console.cloud.google.com>
GOOGLE_CLIENT_SECRET=<depuis-console.cloud.google.com>
GOOGLE_CALLBACK_URL=<url-de-callback-google>
# FACEBOOK_APP_ID=<optionnel>
# FACEBOOK_APP_SECRET=<optionnel>
# FACEBOOK_CALLBACK_URL=<url-de-callback-facebook>
FRONT_URL=<url-du-front>
# Le premier utilisateur (Google ou dev-login) avec cet email devient automatiquement admin.
ADMIN_BOOTSTRAP_EMAIL=<email-du-premier-admin>
# true en local pour activer POST /auth/dev-login ; absent/false ailleurs.
ENABLE_DEV_LOGIN=false
