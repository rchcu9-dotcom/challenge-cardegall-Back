PORT=3010
CORS_ORIGINS=https://stcardegallstg.z6.web.core.windows.net
FRONT_URL=https://stcardegallstg.z6.web.core.windows.net
GOOGLE_CALLBACK_URL=https://challenge-cardegall-back.proudcoast-98490a89.westeurope.azurecontainerapps.io/auth/google/callback
# Réutilise la même base AlwaysData que le local : rchcu11_cardegall_test (bac à sable de test,
# pas de DB staging dédiée à ce stade) — voir DATABASE_URL dans back/.env.local.
# Pour basculer le Container App staging sur cette base :
#   az containerapp update --name challenge-cardegall-back --resource-group rg-challenge-cardegall-staging \
#     --set-env-vars DATABASE_URL="mysql://<user>:<password>@<host>:3306/rchcu11_cardegall_test?ssl=true"
ENABLE_DEV_LOGIN=true
# TODO Lionel : créer un OAuth Client ID sur console.cloud.google.com (APIs & Services > Identifiants)
#   - Type : Application Web
#   - Origine JavaScript autorisée : https://stcardegallstg.z6.web.core.windows.net
#   - URI de redirection autorisée : https://challenge-cardegall-back.proudcoast-98490a89.westeurope.azurecontainerapps.io/auth/google/callback
# Puis injecter sur le Container App staging :
#   az containerapp update --name challenge-cardegall-back --resource-group rg-challenge-cardegall-staging \
#     --set-env-vars GOOGLE_CLIENT_ID=<client-id> GOOGLE_CLIENT_SECRET=<client-secret>
# Tant que ces deux variables ne sont pas renseignées, GET /auth/google répond 503 (GoogleConfiguredGuard)
# et POST /auth/dev-login reste le mécanisme de connexion fonctionnel en staging.
GOOGLE_CLIENT_ID=<a-renseigner-via-console.cloud.google.com>
GOOGLE_CLIENT_SECRET=<a-renseigner-via-console.cloud.google.com>
