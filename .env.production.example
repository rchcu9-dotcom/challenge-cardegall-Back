PORT=3010
CORS_ORIGINS=https://challenge-cardegall.web.app
FRONT_URL=https://challenge-cardegall.web.app
GOOGLE_CALLBACK_URL=https://challenge-cardegall-back-585494077059.europe-west9.run.app/auth/google/callback
# Base AlwaysData dédiée à la prod (rchcu11_cardegall), distincte de la base de test
# (rchcu11_cardegall_test) utilisée par le local et le staging Azure — cf.
# docs/specs/basculer-local-et-prod-sur-la-bdd-always-data-de-test-rchcu1.md (mise à jour du 2026-07-13).
# Schéma synchronisé via `prisma db push` (migrate deploy indisponible sur AlwaysData, pas de shadow DB).
# Injecté sur Cloud Run via :
#   gcloud run services update challenge-cardegall-back --project=challenge-cardegall --region=europe-west9 \
#     --update-env-vars DATABASE_URL="mysql://<user>:<password>@<host>:3306/rchcu11_cardegall?ssl=true"
ENABLE_DEV_LOGIN=true
# TODO Lionel : créer un OAuth Client ID sur console.cloud.google.com (projet challenge-cardegall, APIs & Services > Identifiants)
#   - Type : Application Web
#   - Origine JavaScript autorisée : https://challenge-cardegall.web.app
#   - URI de redirection autorisée : https://challenge-cardegall-back-585494077059.europe-west9.run.app/auth/google/callback
# Puis injecter sur Cloud Run :
#   gcloud run services update challenge-cardegall-back --project=challenge-cardegall --region=europe-west9 \
#     --update-env-vars GOOGLE_CLIENT_ID=<client-id>,GOOGLE_CLIENT_SECRET=<client-secret>
# Tant que ces deux variables ne sont pas renseignées, GET /auth/google répond 503 (GoogleConfiguredGuard)
# et POST /auth/dev-login reste le mécanisme de connexion fonctionnel en prod.
GOOGLE_CLIENT_ID=<a-renseigner-via-console.cloud.google.com>
GOOGLE_CLIENT_SECRET=<a-renseigner-via-console.cloud.google.com>
